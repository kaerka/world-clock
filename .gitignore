# --- Secrets / credentials (never commit these) ---
secrets.py
settings.toml
# Keep the templates tracked:
!secrets.py.template
!settings.toml.template

# --- Local runtime config (Pi/Spectra; may hold keys, locations, host info) ---
# Forward-looking: for the planned on-device config / web UI. Keep *.template tracked.
*.local.toml
*.local.json
config.local.*
!*.local.*.template

# --- CircuitPython board-generated files ---
boot_out.txt          # contains the board's MAC address and UID
*.uf2

# --- CircuitPython libraries (download from the Adafruit bundle, see README) ---
lib/

# --- Agent handoff notes (local only; manually carried between systems) ---
PROJECT_CONTEXT.md

# --- Python / editor / OS cruft ---
__pycache__/
*.py[cod]

# --- Pillow bitmap-font build artifacts (generated from .bdf at runtime) ---
*.pil
*.pbm
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- CIRCUITPY drive metadata (if a board folder is copied in) ---
.metadata_never_index
.Trashes
.Trash-1000
.fseventsd/
"System Volume Information/"
