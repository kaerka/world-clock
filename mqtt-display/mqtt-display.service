[Unit]
Description=Matrix MQTT display (Pi4 + Adafruit HAT) — clock idle, MQTT messages on demand
After=network-online.target time-sync.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/kaerka/world-clock/mqtt-display
ExecStart=/usr/bin/python3 /home/kaerka/world-clock/mqtt-display/display.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
